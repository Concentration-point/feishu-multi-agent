# 飞书应用凭证（飞书开放平台 -> 应用详情 -> 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格配置
# URL 示例: https://xxx.feishu.cn/base/APP_TOKEN?table=TABLE_ID
BITABLE_APP_TOKEN=app_xxxxxxxxxxxxxxxx
PROJECT_TABLE_ID=tblxxxxxxxxxxxxxxxx
CONTENT_TABLE_ID=tblxxxxxxxxxxxxxxxx
EXPERIENCE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# 经验池配置（可选）
EXPERIENCE_CONFIDENCE_THRESHOLD=0.7
EXPERIENCE_MAX_PER_CATEGORY=3
EXPERIENCE_TOP_K=5

# IM 群聊 ID（用于广播，可留空）
FEISHU_CHAT_ID=

# 飞书知识空间 ID（用于知识库同步，可留空）
WIKI_SPACE_ID=

# 本地知识库目录与同步扫描间隔（秒）
KNOWLEDGE_BASE_PATH=knowledge
# 上行同步（本地 → 飞书，仅 07-10 白名单目录）
SYNC_INTERVAL=3600
# 下行同步（飞书 → 本地，仅 01-06 人类维护知识层）
WIKI_DOWNLOAD_INTERVAL=1800
WIKI_DOWNLOAD_ENABLED=true

# 人类审核配置（模块三：人机协同）
# AUTO_APPROVE_HUMAN_REVIEW: true 时跳过人类审核直接通过（Demo 快速跑通模式）
# HUMAN_REVIEW_TIMEOUT: 等待人类回复的超时秒数，默认 300
# HUMAN_REVIEW_POLL_INTERVAL: 轮询间隔秒数，默认 5
AUTO_APPROVE_HUMAN_REVIEW=false
HUMAN_REVIEW_TIMEOUT=300
HUMAN_REVIEW_POLL_INTERVAL=5

# Webhook 服务配置（阶段七）
# WEBHOOK_PORT: 本地 FastAPI 服务端口
# WEBHOOK_VERIFICATION_TOKEN: 飞书事件订阅中的 Verification Token
WEBHOOK_PORT=8000
WEBHOOK_VERIFICATION_TOKEN=

# LLM 配置（支持任意 OpenAI 兼容接口）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o

# 联网搜索 / 网页抓取（仅策略师使用）
# Tavily API: https://tavily.com  注册后拿 API Key，免费额度 1000 次/月
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_DEFAULT_MAX_RESULTS=5
TAVILY_TIMEOUT_SECONDS=15
# web_fetch 正文截断：默认 10000 字，上限 50000 字
WEB_FETCH_MAX_CHARS_DEFAULT=10000
WEB_FETCH_MAX_CHARS_LIMIT=50000
WEB_FETCH_MAX_BYTES=5242880
WEB_FETCH_TIMEOUT_SECONDS=10

# 事件订阅配置说明
# 1. 在飞书开放平台开启事件订阅（Event Subscription）
# 2. 请求地址填: http(s)://<your-host>:WEBHOOK_PORT/webhook/event
# 3. Verification Token 填入上面的 WEBHOOK_VERIFICATION_TOKEN
# 4. 至少订阅多维表格新增记录事件：bitable.record.created_v1
# 5. 相关权限需覆盖多维表格读取/写入、知识库写入、IM 发消息（按你的使用范围开启）
# 审核流转策略
# 默认审核通过率阈值；具体项目类型可在 config.py 的 REVIEW_THRESHOLDS_BY_PROJECT_TYPE 中调整
REVIEW_PASS_THRESHOLD_DEFAULT=0.6
# 审核不达标或命中红线时，最多触发几次 copywriter 返工 + reviewer 复审
REVIEW_MAX_RETRIES=2
# 审核总评中命中以下关键词时，视为红线风险，一票否决
REVIEW_RED_FLAG_KEYWORDS=严重合规风险,虚假宣传,绝对化用语,医疗化表述,编造数据,事实错误,严重不适配
